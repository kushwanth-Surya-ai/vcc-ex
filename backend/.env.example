# ─── Database ────────────────────────────────────────────────────────────────
# Full async SQLAlchemy connection URL (postgresql+asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://vcc_user:vcc_password@localhost:5432/vcc_db

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
# Must be at least 64 random characters – generate with: openssl rand -hex 64
JWT_SECRET=replace-with-long-random-secret-min-64-chars

# HMAC signing algorithm for JWTs
JWT_ALGORITHM=HS256

# How long access tokens live (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# How long refresh tokens live (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# API key for the detection pipeline (POST /api/events).
# Must be at least 32 random characters – generate with: openssl rand -hex 32
SERVICE_API_KEY=replace-with-long-random-api-key-min-32-chars

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Cookie security ─────────────────────────────────────────────────────────
# Set to true in production (requires HTTPS); false is safe for local dev
COOKIE_SECURE=false

# ─── Scheduler ───────────────────────────────────────────────────────────────
# How often (in minutes) the materialized views are refreshed
MV_REFRESH_INTERVAL_MINUTES=5

# ─── Rate limiting ───────────────────────────────────────────────────────────
# Redis URI for distributed rate-limit state; leave blank to use in-process memory
RATE_LIMIT_STORAGE_URI=

# Max login attempts per minute per IP
LOGIN_RATE_LIMIT=5/minute

# ─── Streaming / media ───────────────────────────────────────────────────────
# Base URL of the optional RTSP-to-HLS transcoding sidecar
STREAM_BASE_URL=http://localhost:8001

# ─── Default Camera Pipeline Options ─────────────────────────────────────────
# Default lane ID assigned to new cameras if not specified (default: 1)
VCC_DEFAULT_LANE_ID=1
# Default tracking crossing direction: 'in', 'out', or 'both' (default: both)
VCC_DEFAULT_DIRECTION=both
# Default line Y-position fraction (0.0 to 1.0) for vehicle crossing line (default: 0.5)
VCC_DEFAULT_LINE_Y=0.5

