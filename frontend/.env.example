# The FastAPI backend: REST + the /ws event socket.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

VITE_POLL_INTERVAL_MS=30000

# The detection process's MJPEG server (detection/streamer.py), NOT the backend.
# It is a separate aiohttp server on its own port -- 8001 by default, matching
# STREAM_PORT in the root .env and STREAM_BASE_URL in backend/.env. The backend
# has no /stream/{camera_id} route, so pointing this at 8000 makes every live
# preview 404: uploaded videos and live cameras alike render "stream
# unavailable" while detection is in fact running perfectly.
VITE_STREAM_BASE_URL=http://localhost:8001
