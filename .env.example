# Global Environment Variables

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vcc_db
JWT_SECRET=replace_with_a_long_secure_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
SERVICE_API_KEY=replace_with_a_long_secure_service_api_key
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
COOKIE_SECURE=false
MV_REFRESH_INTERVAL_MINUTES=5
RATE_LIMIT_STORAGE_URI=
LOGIN_RATE_LIMIT=5/minute
STREAM_BASE_URL=http://localhost:8001

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live
VITE_POLL_INTERVAL_MS=30000

# Detection Pipeline
VCC_MODEL_PATH=yolo26s.pt
VCC_FALLBACK_MODEL=yolo11s.pt
VCC_TRACKER=bytetrack.yaml
VCC_CONF=0.45
VCC_API_URL=http://localhost:8000
VCC_SERVICE_API_KEY=replace_with_a_long_secure_service_api_key
STREAM_PORT=8001
FRAME_BUFFER_SIZE=30
